rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Configurações do Bolão (Chave PIX, etc.)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true; // Permitido para o painel admin local
    }
    
    // Jogos cadastrados
    match /games/{gameId} {
      allow read: if true;
      allow write: if true; // Permitido para o painel admin local
    }
    
    // Palpites enviados
    match /bets/{betId} {
      allow read: if true;
      allow create: if true; // Qualquer torcedor pode enviar palpite
      allow update, delete: if true; // Permitido para o painel admin alterar status/pontos
    }
  }
}
